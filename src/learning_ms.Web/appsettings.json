{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DATABASE_HOST};Port=${DATABASE_PORT};Database=${DATABASE_NAME};Username=${DATABASE_USER};Password=${DATABASE_PASSWORD}"
  },
  "ApiSettings": {
    "Version": "${API_VERSION}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}",
    "AccessTokenExpirationMinutes": "${JWT_ACCESS_TOKEN_EXPIRATION_MINUTES}",
    "RefreshTokenExpirationDays": "${JWT_REFRESH_TOKEN_EXPIRATION_DAYS}"
  },
  "ResendSettings": {
    "ApiKey": "${RESEND_API_KEY}",
    "SenderEmail": "${RESEND_SENDER_EMAIL}",
    "SenderName": "${RESEND_SENDER_NAME}"
  },
  "CacheSettings": {
    "UseRedis": "${CACHE_USE_REDIS}",
    "RedisConnectionString": "${REDIS_CONNECTION_STRING}",
    "DefaultExpirationMinutes": "${CACHE_DEFAULT_EXPIRATION_MINUTES}",
    "LocalCacheExpirationMinutes": "${CACHE_LOCAL_EXPIRATION_MINUTES}"
  },
  "RateLimitSettings": {
    "PermitLimit": "${RATE_LIMIT_PERMIT}",
    "WindowMinutes": "${RATE_LIMIT_WINDOW_MINUTES}"
  },
 "StripeSettings": {
    "ApiKey": "${STRIPE_API_KEY}",
    "DefaultCurrency": "${STRIPE_DEFAULT_CURRENCY}"
  },
  "PayPalSettings": {
    "ClientId": "${PAYPAL_API_CLIENT}",
    "SecretKey": "${PAYPAL_SECRET_KEY}",
    "Environment": "${PAYPAL_ENVIRONMENT}"
  },
  "MinioSettings": {
    "Endpoint": "${MINIO_ENDPOINT}",
    "AccessKey": "${MINIO_ACCESS_KEY}",
    "SecretKey": "${MINIO_SECRET_KEY}",
    "BucketName": "${MINIO_BUCKET_NAME}",
    "UseSSL": "${MINIO_USE_SSL}",
    "Region": "${MINIO_REGION}"
  },
  "FileUploadSettings": {
    "MaxFileSizeBytes": "${FILE_MAX_SIZE_BYTES}",
    "AllowedTypes": {
      "application/pdf":                                                                  [".pdf"],
      "application/vnd.ms-excel":                                                         [".xls"],
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":               [".xlsx"],
      "application/msword":                                                               [".doc"],
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document":         [".docx"],
      "text/csv":                                                                         [".csv"],
      "image/png":                                                                        [".png"],
      "image/jpeg":                                                                       [".jpg", ".jpeg"],
      "video/mp4":                                                                        [".mp4"],
      "video/x-msvideo":                                                                  [".avi"],
      "video/x-matroska":                                                                 [".mkv"]
    }
  },
  "CorsSettings": {
  "PolicyName": "DefaultCorsPolicy",
  "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}",
  "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
  "AllowedHeaders": [ "Content-Type", "Authorization", "X-Requested-With", "Accept", "Origin" ],
  "ExposedHeaders": [ "X-Pagination", "X-Total-Count", "Location" ],
  "AllowCredentials": true,
  "PreflightMaxAgeSeconds": 600
}, 
  "FirebaseSettings": {
    "ProjectId": "${FIREBASE_PROJECT_ID}",
    "KeyId": "${FIREBASE_KEY_ID}",
    "PrivateKey": "${FIREBASE_PRIVATE_KEY}",
    "ClientEmail": "${FIREBASE_CLIENT_EMAIL}",
    "ClientId": "${FIREBASE_CLIENT_ID}"
  },
  "RoleEmailSettings": {
    "SuperAdminEmail": "${SUPER_ADMIN_EMAIL}",
    "SuperAdminPassword": "${SUPER_ADMIN_PASSWORD}",

    "HeadOfDepartmentEmail": "${HEAD_OF_DEPARTMENT_EMAIL}",
    "HeadOfDepartmentPassword": "${HEAD_OF_DEPARTMENT_PASSWORD}",

    "VicePrincipalEmail": "${VICE_PRINCIPAL_EMAIL}",
    "VicePrincipalPassword": "${VICE_PRINCIPAL_PASSWORD}",

    "RegistrarEmail": "${REGISTRAR_EMAIL}",
    "RegistrarPassword": "${REGISTRAR_PASSWORD}",

    "BursarEmail": "${BURSAR_EMAIL}",
    "BursarPassword": "${BURSAR_PASSWORD}",

    "AccountantEmail": "${ACCOUNTANT_EMAIL}",
    "AccountantPassword": "${ACCOUNTANT_PASSWORD}",

    "FinanceManagerEmail": "${FINANCE_MANAGER_EMAIL}",
    "FinanceManagerPassword": "${FINANCE_MANAGER_PASSWORD}",

