{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DATABASE_HOST};Port=${DATABASE_PORT};Database=${DATABASE_NAME};Username=${DATABASE_USER};Password=${DATABASE_PASSWORD}"
  },
  "ApiSettings": {
    "Version": "${API_VERSION}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "AccessTokenExpiration": "${JWT_ACCESS_TOKEN}",
    "RefreshTokenExpiration": "${JWT_REFRESH_TOKEN}",
    "Expiration": "${JWT_EXPIRATION}",
    "RefreshExpiration": "${JWT_REFRESH_EXPIRATION}"
  },
  "StripeSettings": {
    "ApiKey": "${STRIPE_API_KEY}"
  },
  "PayPalSettings": {
    "ClientId": "${PAYPAL_API_CLIENT}",
    "SecretKey": "${PAYPAL_SCERET_KEY}"
  },
  "MailerSendSettings": {
    "ApiKey": "${MAILERSEND_API_KEY}",
    "SenderEmail": "${MAILERSEND_EMAIL_SENDER}",
    "SenderName": "${MAILERSEND_EMAIL_NAME}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}