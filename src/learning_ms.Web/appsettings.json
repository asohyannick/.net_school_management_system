    "AdmissionsOfficerPassword": "${ADMISSIONS_OFFICER_PASSWORD}",

    "ExamOfficerEmail": "${EXAM_OFFICER_EMAIL}",
    "ExamOfficerPassword": "${EXAM_OFFICER_PASSWORD}",

