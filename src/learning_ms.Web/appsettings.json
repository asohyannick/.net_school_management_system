    "ResearchCoordinatorEmail": "${RESEARCH_COORDINATOR_EMAIL}",
    "ResearchCoordinatorPassword": "${RESEARCH_COORDINATOR_PASSWORD}",

    "TrainingCoordinatorEmail": "${TRAINING_COORDINATOR_EMAIL}",
    "TrainingCoordinatorPassword": "${TRAINING_COORDINATOR_PASSWORD}",

    "FacilitiesManagerEmail": "${FACILITIES_MANAGER_EMAIL}",
    "FacilitiesManagerPassword": "${FACILITIES_MANAGER_PASSWORD}",

    "MaintenanceSupervisorEmail": "${MAINTENANCE_SUPERVISOR_EMAIL}",
    "MaintenanceSupervisorPassword": "${MAINTENANCE_SUPERVISOR_PASSWORD}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}